{
  "name": "llm-for-zotero",
  "type": "module",
  "version": "3.7.12",
  "description": "LLM assistant for Zotero in the reader side panel",
  "config": {
    "addonName": "llm-for-zotero",
    "addonID": "zotero-llm@github.com.yilewang",
    "addonRef": "llmforzotero",
    "addonInstance": "LLMForZotero",
    "prefsPrefix": "extensions.zotero.llmforzotero"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yilewang/llm-for-zotero.git"
  },
  "author": "Yile Wang",
  "bugs": {
    "url": "https://github.com/yilewang/llm-for-zotero/issues"
  },
  "homepage": "https://github.com/yilewang/llm-for-zotero#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && npm run typecheck",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && zotero-plugin test",
    "test:unit": "npx tsx node_modules/mocha/bin/mocha.js 'test/**/*.test.ts'",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "katex": "^0.16.28",
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
